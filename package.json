{
  "name": "bulk-atr-producer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "PORT=3001 tsx --watch server/main.ts",
    "dev:vercel": "vercel dev",
    "build": "tsc --project tsconfig.server.json",
    "start": "NODE_ENV=production node build/runtime/server/main.js",
    "test": "rstest --project api",
    "check": "biome check . && tsc --noEmit && tsc --project tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "@vercel/blob": "^2.3.1",
    "@vercel/functions": "^3.4.3",
    "hono": "^4.12.4",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@rstest/core": "^0.9.0",
    "@types/node": "^24.6.0",
    "@types/pg": "^8.18.0",
    "pg-mem": "^3.0.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
