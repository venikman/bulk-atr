### Health Check
# Returns {"status":"ok"} if the server and database are reachable.
# Returns 503 with {"status":"error","detail":"..."} if the database is unreachable.
# Use this to verify the server is up before running any FHIR calls.

GET {{baseUrl}}/health
Accept: application/json

?? status == 200

### Read CapabilityStatement
# Returns the server's FHIR CapabilityStatement.
# Declares supported FHIR version (4.0.1), ATR producer profile,
# available resource types and interactions, the $davinci-data-export operation,
# search parameters (Group: identifier, name), and SMART security extensions.
# Clients should read this first to discover server capabilities programmatically.

GET {{baseUrl}}/fhir/metadata
Accept: application/fhir+json

?? status == 200
