### Patient Search by Name
# Search patients by name (partial match across family and given names).

GET {{baseUrl}}/fhir/Patient?name=Smith
Accept: application/fhir+json

?? status == 200

### Patient Search by Birthdate
# Search patients by birth date range using ge/le prefixes.

GET {{baseUrl}}/fhir/Patient?birthdate=ge1960-01-01&birthdate=le2000-12-31
Accept: application/fhir+json

?? status == 200

### Patient Search by Gender
# Search patients by administrative gender.

GET {{baseUrl}}/fhir/Patient?gender=female
Accept: application/fhir+json

?? status == 200

### Patient Search by General Practitioner
# Search patients by assigned general practitioner reference.

GET {{baseUrl}}/fhir/Patient?general-practitioner=PractitionerRole/{{practitionerRoleId}}
Accept: application/fhir+json

?? status == 200

### Encounter Search by Patient
# Search encounters for a specific patient.

GET {{baseUrl}}/fhir/Encounter?patient=Patient/{{patientId}}
Accept: application/fhir+json

?? status == 200

### Encounter Search by Date
# Search encounters by date range using ge/le prefixes.

GET {{baseUrl}}/fhir/Encounter?date=ge2025-01-01&date=le2025-12-31
Accept: application/fhir+json

?? status == 200

### Encounter Search by Status
# Search encounters by status (planned, arrived, triaged, in-progress, onleave, finished, cancelled).

GET {{baseUrl}}/fhir/Encounter?status=finished
Accept: application/fhir+json

?? status == 200

### Encounter Search by Type
# Search encounters by CPT type code.

GET {{baseUrl}}/fhir/Encounter?type=http://www.ama-assn.org/go/cpt|99213
Accept: application/fhir+json

?? status == 200

### Encounter Search by Practitioner
# Search encounters by participating practitioner.

GET {{baseUrl}}/fhir/Encounter?practitioner=Practitioner/{{practitionerId}}
Accept: application/fhir+json

?? status == 200

### Encounter Search by Location
# Search encounters by location.

GET {{baseUrl}}/fhir/Encounter?location=Location/{{locationId}}
Accept: application/fhir+json

?? status == 200

### Encounter Search by Reason Code
# Search encounters by ICD-10 reason code.

GET {{baseUrl}}/fhir/Encounter?reason-code=http://hl7.org/fhir/sid/icd-10-cm|E11.9
Accept: application/fhir+json

?? status == 200

### Encounter Search Combined
# Combined encounter search with practitioner, date range, and status.

GET {{baseUrl}}/fhir/Encounter?practitioner=Practitioner/{{practitionerId}}&date=ge2025-01-01&status=finished
Accept: application/fhir+json

?? status == 200

### Condition Search by Patient
# Search conditions for a specific patient (problem list).

GET {{baseUrl}}/fhir/Condition?patient=Patient/{{patientId}}
Accept: application/fhir+json

?? status == 200

### Condition Search by Code
# Search conditions by ICD-10 code prefix.

GET {{baseUrl}}/fhir/Condition?code=http://hl7.org/fhir/sid/icd-10-cm|E11
Accept: application/fhir+json

?? status == 200

### Condition Search by Clinical Status
# Search active conditions filtered by ICD-10 code.

GET {{baseUrl}}/fhir/Condition?clinical-status=active&code=http://hl7.org/fhir/sid/icd-10-cm|I10
Accept: application/fhir+json

?? status == 200

### Condition Search by Category
# Search conditions by category (encounter-diagnosis or problem-list-item) for a patient.

GET {{baseUrl}}/fhir/Condition?category=encounter-diagnosis&patient=Patient/{{patientId}}
Accept: application/fhir+json

?? status == 200

