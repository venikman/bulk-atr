# Search procedures for a specific patient.

GET {{baseUrl}}/fhir/Procedure?patient=Patient/{{patientId}}
Accept: application/fhir+json

?? status == 200

### Procedure Search by Code
# Search procedures by CPT code.

GET {{baseUrl}}/fhir/Procedure?code=http://www.ama-assn.org/go/cpt|99385
Accept: application/fhir+json

?? status == 200

### Observation Search Vitals
# Search vital-signs observations for a patient.

GET {{baseUrl}}/fhir/Observation?patient=Patient/{{patientId}}&category=vital-signs
Accept: application/fhir+json

?? status == 200

### Observation Search Labs
# Search laboratory observations for a patient.

GET {{baseUrl}}/fhir/Observation?patient=Patient/{{patientId}}&category=laboratory
Accept: application/fhir+json

?? status == 200

### Observation Search by LOINC
# Search observations by LOINC code (4548-4 = Hemoglobin A1c) with date filter.

GET {{baseUrl}}/fhir/Observation?code=http://loinc.org|4548-4&date=ge2025-01-01
Accept: application/fhir+json

?? status == 200

### MedicationRequest Search by Patient
# Search active medication requests for a patient.

GET {{baseUrl}}/fhir/MedicationRequest?patient=Patient/{{patientId}}&status=active
Accept: application/fhir+json

?? status == 200

### MedicationRequest Search by Code
# Search medication requests by RxNorm code (860975 = Metformin 500mg).

GET {{baseUrl}}/fhir/MedicationRequest?code=http://www.nlm.nih.gov/research/umls/rxnorm|860975
Accept: application/fhir+json

?? status == 200

