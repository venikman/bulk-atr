meta {
  name: MedicationRequest Search by Patient
  type: http
  seq: 22
}

get {
  url: {{baseUrl}}/fhir/MedicationRequest?patient=Patient/{{patientId}}&status=active
  body: none
  auth: none
}

tests {
  test("Returns a searchset Bundle", function() {
    expect(res.status).to.equal(200);
    expect(res.body.resourceType).to.equal("Bundle");
    expect(res.body.type).to.equal("searchset");
  });
}

docs {
  Search active medication requests for a patient.
}
