meta {
  name: Observation Search Labs
  type: http
  seq: 20
}

get {
  url: {{baseUrl}}/fhir/Observation?patient=Patient/{{patientId}}&category=laboratory
  body: none
  auth: none
}

tests {
  test("Returns a searchset Bundle", function() {
    expect(res.status).to.equal(200);
    expect(res.body.resourceType).to.equal("Bundle");
    expect(res.body.type).to.equal("searchset");
  });
}

docs {
  Search laboratory observations for a patient.
}
