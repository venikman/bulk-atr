meta {
  name: Condition Search by Patient
  type: http
  seq: 13
}

get {
  url: {{baseUrl}}/fhir/Condition?patient=Patient/{{patientId}}
  body: none
  auth: none
}

tests {
  test("Returns a searchset Bundle", function() {
    expect(res.status).to.equal(200);
    expect(res.body.resourceType).to.equal("Bundle");
    expect(res.body.type).to.equal("searchset");
  });
}

docs {
  Search conditions for a specific patient (problem list).
}
