meta {
  name: Patient Search by General Practitioner
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/fhir/Patient?general-practitioner=PractitionerRole/{{practitionerRoleId}}
  body: none
  auth: none
}

tests {
  test("Returns a searchset Bundle", function() {
    expect(res.status).to.equal(200);
    expect(res.body.resourceType).to.equal("Bundle");
    expect(res.body.type).to.equal("searchset");
  });
}

docs {
  Search patients by assigned general practitioner reference.
}
