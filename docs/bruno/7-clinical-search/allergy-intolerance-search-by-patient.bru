meta {
  name: AllergyIntolerance Search by Patient
  type: http
  seq: 24
}

get {
  url: {{baseUrl}}/fhir/AllergyIntolerance?patient=Patient/{{patientId}}
  body: none
  auth: none
}

tests {
  test("Returns a searchset Bundle", function() {
    expect(res.status).to.equal(200);
    expect(res.body.resourceType).to.equal("Bundle");
    expect(res.body.type).to.equal("searchset");
  });
}

docs {
  Search allergy intolerances for a patient.
}
