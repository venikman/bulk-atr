meta {
  name: MedicationRequest Search by Code
  type: http
  seq: 23
}

get {
  url: {{baseUrl}}/fhir/MedicationRequest?code=http://www.nlm.nih.gov/research/umls/rxnorm|860975
  body: none
  auth: none
}

tests {
  test("Returns a searchset Bundle", function() {
    expect(res.status).to.equal(200);
    expect(res.body.resourceType).to.equal("Bundle");
    expect(res.body.type).to.equal("searchset");
  });
}

docs {
  Search medication requests by RxNorm code (860975 = Metformin 500mg).
}
