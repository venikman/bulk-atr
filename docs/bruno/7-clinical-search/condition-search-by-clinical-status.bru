meta {
  name: Condition Search by Clinical Status
  type: http
  seq: 15
}

get {
  url: {{baseUrl}}/fhir/Condition?clinical-status=active&code=http://hl7.org/fhir/sid/icd-10-cm|I10
  body: none
  auth: none
}

tests {
  test("Returns a searchset Bundle", function() {
    expect(res.status).to.equal(200);
    expect(res.body.resourceType).to.equal("Bundle");
    expect(res.body.type).to.equal("searchset");
  });
}

docs {
  Search active conditions filtered by ICD-10 code.
}
