meta {
  name: Encounter Search by Practitioner
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/fhir/Encounter?practitioner=Practitioner/{{practitionerId}}
  body: none
  auth: none
}

tests {
  test("Returns a searchset Bundle", function() {
    expect(res.status).to.equal(200);
    expect(res.body.resourceType).to.equal("Bundle");
    expect(res.body.type).to.equal("searchset");
  });
}

docs {
  Search encounters by participating practitioner.
}
