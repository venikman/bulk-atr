meta {
  name: Unknown FHIR route
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/fhir/UnknownResource
  body: none
  auth: none
}

tests {
  test("Returns 404 OperationOutcome", function() {
    expect(res.status).to.equal(404);
    expect(res.body.resourceType).to.equal("OperationOutcome");
  });
}

docs {
  Accessing an unsupported FHIR resource type returns 404 OperationOutcome.
}
