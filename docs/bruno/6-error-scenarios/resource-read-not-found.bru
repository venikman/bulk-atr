meta {
  name: Resource read — not found
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/fhir/Patient/does-not-exist-999
  body: none
  auth: none
}

tests {
  test("Returns 404 OperationOutcome", function() {
    expect(res.status).to.equal(404);
    expect(res.body.resourceType).to.equal("OperationOutcome");
    expect(res.body.issue[0].code).to.equal("not-found");
  });
}

docs {
  Reading a resource that does not exist returns 404.

  Expected: OperationOutcome with code `not-found`.
}
